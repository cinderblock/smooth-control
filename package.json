{
  "name": "@cinderblock/smooth-control",
  "version": "0.0.0",
  "description": "Node.js API for controlling Smooth Control BLDC motors (Quantum Drive & Hover Drive) over USB HID",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/SmoothControl.d.ts",
      "default": "./dist/SmoothControl.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "!dist/**/*.test.*",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinderblock/smooth-control.git"
  },
  "homepage": "https://github.com/cinderblock/smooth-control#readme",
  "bugs": {
    "url": "https://github.com/cinderblock/smooth-control/issues"
  },
  "keywords": [
    "smooth-control",
    "quantum-drive",
    "hover-drive",
    "bldc",
    "motor",
    "usb",
    "hid",
    "mlx90363"
  ],
  "author": "Cameron Tacklind <cameron@tacklind.com> (https://cameron.tacklind.com)",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "prepare": "test -d dist || npm run build",
    "test": "npm run build && node --test dist/SmoothControl.test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@cinderblock/mlx90363": "github:cinderblock/node-MLX90363",
    "usb": "^2.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
